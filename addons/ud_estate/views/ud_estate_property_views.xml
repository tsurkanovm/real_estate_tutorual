<?xml version="1.0"?>
<odoo>
    <!--    Property views -->
    <record id="ud_estate_property_action" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">ud_estate.property</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

    <record id="ud_estate_property_view_list" model="ir.ui.view">
        <field name="name">ud_estate.property.view.list</field>
        <field name="model">ud_estate.property</field>
        <field name="arch" type="xml">
            <list string="Properties" default_order="price asc"
                  decoration-muted="state == 'sold'"
                  decoration-danger="state == 'cancelled'"
                  decoration-success="state == 'received' or state == 'accepted'"
                  decoration-bf="state == 'accepted'">
                <field name="id"/>
                <field name="name"/>
                <field name="postcode"/>
                <field name="tag_ids" widget="many2many_tags" string="" options="{'color_field': 'color'}"/>
                <field name="bedrooms"/>
                <field name="living_area" string="Living Area (sqm)"/>
                <field name="price"/>
                <field name="best_offer"/>
                <field name="available_from" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="ud_estate_property_view_form" model="ir.ui.view">
        <field name="name">ud_estate.property.view.form</field>
        <field name="model">ud_estate.property</field>
        <field name="arch" type="xml">
            <form string="Property">
                <header>
                    <button name="action_set_sold" type="object" string="SOLD"
                            invisible="state == 'sold' or state == 'cancelled'"/>
                    <button name="action_set_cancelled" type="object" string="CANCEL"
                            invisible="state == 'sold' or state == 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="new, received, accepted, sold"/>
                </header>
                <sheet>
                    <group>
                        <field name="tag_ids" widget="many2many_tags" string="Property Tags" options="{'color_field': 'color'}"/>
                    </group>

                    <group>
                        <group>
                            <field name="type_id" options="{'no_create': True}"/>
                            <field name="postcode"/>
                            <field name="available_from"/>
                        </group>
                        <group>
                            <field name="expected_price"/>
                            <field name="price"/>
                            <field name="best_offer"/>
                        </group>

                        <notebook>
                            <page string="Description">
                                <group>
                                    <field name="name"/>
                                    <field name="bedrooms"/>
                                    <field name="living_area"/>
                                    <field name="facades"/>
                                    <field name="garage"/>
                                    <field name="garden"/>
                                    <field name="garden_area" invisible="not garden"/>
                                    <field name="garden_orientation" invisible="not garden"/>
                                    <field name="total_area"/>
                                </group>
                            </page>
                            <page string="Offers">
                                <field name="offer_ids" widget="one2many" mode="list" readonly="state =='accepted' or state =='sold'"/>
                            </page>
                            <page string="Other information">
                                <group>
                                    <field name="user_id"/>
                                    <field name="partner_id"/>
                                </group>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

<record id="ud_estate_property_view_kanban" model="ir.ui.view">
    <field name="name">ud_estate.property.view.kanban</field>
    <field name="model">ud_estate.property</field>
    <field name="arch" type="xml">
        <kanban default_group_by="type_id" class="o_kanban_example"
        group_create="false" group_edit="false" group_delete="false" records_draggable="false" default_order="price desc">
            <field name="name"/>
            <field name="state"/>
            <field name="expected_price"/>
            <field name="price"/>
             <field name="best_offer"/>
             <field name="tag_ids"/>
            <templates>
                <t t-name="card">
                   <field name="name" class="fw-bolder"/>
                    <div>
                        Expected Price:
                         <field name="expected_price"/>
                    </div>

                    <div t-if="record.state.raw_value == 'received'">
                            Best Offer:
                         <field name="best_offer"/>
                    </div>
                     <div t-if="record.state.raw_value == 'accepted'">
                            Selling Price:
                        <field name="price"/>
                    </div>
                    <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                </t>
            </templates>
        </kanban>
    </field>
</record>

    <record id="ud_estate_property_view_filter" model="ir.ui.view">
        <field name="name">ud_estate.property.view.filter</field>
        <field name="model">ud_estate.property</field>
        <field name="arch" type="xml">
            <search string="Properties">
                <field name="postcode"/>
                <field name="bedrooms"/>
                <field name="price" string="Expected Price"/>
                <field name="living_area" string="Living Area (sqm)"
                       filter_domain="[('living_area', '>=', self)]"/>
                <field name="facades"/>
                <filter string="Available" name="available"
                        domain="['|', ('state', '=', 'new'), ('state', '=', 'received')]"/>
                <group>
                    <filter name="postcode" context="{'group_by': 'postcode'}"/>
                </group>
            </search>
        </field>
    </record>

    <!--  Offer views  -->
    <record id="ud_estate_property_offer_action" model="ir.actions.act_window">
        <field name="name">Property Offers</field>
        <field name="res_model">ud_estate.property.offer</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('property_type_id', '=', active_id)]</field>
    </record>
    <record id="ud_estate_property_offer_view_tree" model="ir.ui.view">
        <field name="name">ud_estate.property.offer.tree</field>
        <field name="model">ud_estate.property.offer</field>
        <field name="arch" type="xml">
            <list string="Offers" editable="bottom" decoration-success="status=='accepted'"
                  decoration-danger="status=='rejected'">
                <field name="price"/>
                <field name="partner_id"/>
                <field name="validity" string="Validity (days)"/>
                <field name="date_deadline"/>
                <button name="action_set_accept" type="object" icon="fa-check" title="Accept Offer"
                        invisible="status == 'accepted' or status == 'rejected'"/>
                <button name="action_set_reject" type="object" icon="fa-close" title="Reject Offer"
                        invisible="status == 'accepted' or status == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="ud_estate_offer_view_form" model="ir.ui.view">
        <field name="name">ud_estate.offer.view.form</field>
        <field name="model">ud_estate.property.offer</field>
        <field name="arch" type="xml">
            <form string="Offer">
                <sheet>
                    <group>
                        <field name="price"/>
                        <field name="partner_id"/>
                        <field name="validity" string="Validity (days)"/>
                        <field name="date_deadline"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--    Property type views -->
    <record id="ud_estate_property_type_action" model="ir.actions.act_window">
        <field name="name">Property Types</field>
        <field name="res_model">ud_estate.property.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="ud_estate_property_type_view_tree" model="ir.ui.view">
        <field name="name">ud_estate.property.type.view.tree</field>
        <field name="model">ud_estate.property.type</field>
        <field name="arch" type="xml">
            <list string="Property Types">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="ud_estate_property_type_view_form" model="ir.ui.view">
        <field name="name">ud_estate.property.type.view.form</field>
        <field name="model">ud_estate.property.type</field>
        <field name="arch" type="xml">
            <form string="Property">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button"
                                name="%(ud_estate_property_offer_action)d"
                                type="action"
                                icon="fa-file-text-o"
                                help="Offers for a type of property">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value d-flex gap-1">
                                    <field name="offer_count" widget="statinfo" nolabel="1" class="oe_inline"/>
                                </span>
                                <span class="o_stat_text">Offers</span>
                            </div>
                        </button>
                    </div>
                    <h1 class="mb32">
                        <field name="name"/>
                    </h1>
                    <notebook>
                        <page string="Properties">
                            <field name="property_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="expected_price"/>
                                    <field name="state" string="Status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!--    Property Tag  views -->
    <record id="ud_estate_property_tag_action" model="ir.actions.act_window">
        <field name="name">Property Tags</field>
        <field name="res_model">ud_estate.property.tag</field>
        <field name="view_mode">list,form</field>
    </record>

    <!--    inherited user form -->
    <record id="res_users_view_form" model="ir.ui.view">
        <field name="name">res.users.view.form.inherit.properties</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
            <page string="Real Estate Properties">
                <field name="property_ids" readonly="1">
                    <list>
                        <field name="name"/>
                        <field name="type_id"/>
                        <field name="expected_price"/>
                        <field name="state"/>
                    </list>
                </field>
            </page>
        </xpath>
        </field>
    </record>

<!--    Dashboard views -->
    <record id="ud_estate_dashboard_action" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">ud_estate.dashboard</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="ud_estate_dashboard_main"/>
    </record>
    <record id="ud_estate_dashboard_form_view" model="ir.ui.view">
        <field name="name">ud.estate.dashboard.form</field>
        <field name="model">ud_estate.dashboard</field>
        <field name="arch" type="xml">
            <form string="Real Estate Dashboard" create="false" edit="false" delete="false">
                <sheet>

                    <!-- OVERVIEW -->
                    <div class="mb-4">
                        <h2>Overview</h2>
                        <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-top: 16px;">
                            <div style="flex: 1 1 220px; min-width: 220px; background: #71639e; color: white; border-radius: 8px; padding: 20px; text-align: center;">
                                <div style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">Total Properties
                                </div>
                                <div style="font-size: 28px; font-weight: 700;">
                                    <field name="total_properties" readonly="1" nolabel="1"/>
                                </div>
                            </div>

                            <div style="flex: 1 1 220px; min-width: 220px; background: #28a745; color: white; border-radius: 8px; padding: 20px; text-align: center;">
                                <div style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">Sold Properties
                                </div>
                                <div style="font-size: 28px; font-weight: 700;">
                                    <field name="sold_properties" readonly="1" nolabel="1"/>
                                </div>
                            </div>

                            <div style="flex: 1 1 220px; min-width: 220px; background: #17a2b8; color: white; border-radius: 8px; padding: 20px; text-align: center;">
                                <div style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">Total Offers</div>
                                <div style="font-size: 28px; font-weight: 700;">
                                    <field name="total_offers" readonly="1" nolabel="1"/>
                                </div>
                            </div>

                            <div style="flex: 1 1 220px; min-width: 220px; background: #f0ad4e; color: white; border-radius: 8px; padding: 20px; text-align: center;">
                                <div style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">Accepted Offers
                                </div>
                                <div style="font-size: 28px; font-weight: 700;">
                                    <field name="accepted_offers" readonly="1" nolabel="1"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- PIPELINE -->
                    <h2>Property Pipeline</h2>
                    <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-top: 16px;">
                        <div style="flex: 1 1 220px; min-width: 220px; background: #6c757d; color: white; border-radius: 8px; padding: 20px; text-align: center;">
                            <div style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">New Properties</div>
                            <div style="font-size: 28px; font-weight: 700;">
                                <field name="new_properties" readonly="1" nolabel="1"/>
                            </div>
                        </div>

                        <div style="flex: 1 1 220px; min-width: 220px; background: #17a2b8; color: white; border-radius: 8px; padding: 20px; text-align: center;">
                            <div style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">Received Properties
                            </div>
                            <div style="font-size: 28px; font-weight: 700;">
                                <field name="received_properties" readonly="1" nolabel="1"/>
                            </div>
                        </div>

                        <div style="flex: 1 1 220px; min-width: 220px; background: #f0ad4e; color: white; border-radius: 8px; padding: 20px; text-align: center;">
                            <div style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">Accepted Properties
                            </div>
                            <div style="font-size: 28px; font-weight: 700;">
                                <field name="accepted_properties" readonly="1" nolabel="1"/>
                            </div>
                        </div>

                        <div style="flex: 1 1 220px; min-width: 220px; background: #28a745; color: white; border-radius: 8px; padding: 20px; text-align: center;">
                            <div style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">Sold Properties</div>
                            <div style="font-size: 28px; font-weight: 700;">
                                <field name="sold_properties" readonly="1" nolabel="1"/>
                            </div>
                        </div>
                    </div>

                    <!-- PRICES -->
<div class="mt-4">
    <h2>Prices</h2>
    <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-top: 16px;">
        <div style="flex: 1 1 320px; min-width: 320px; background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 8px; padding: 20px;">
            <div style="font-size: 16px; font-weight: 600; margin-bottom: 12px; color: #212529;">
                Avg Expected Price
            </div>
            <div style="font-size: 28px; font-weight: 700; color: #212529;">
                <field name="currency_id" invisible="1"/>
                <field name="avg_expected_price"
                       readonly="1"
                       nolabel="1"
                       widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
            </div>
        </div>

        <div style="flex: 1 1 320px; min-width: 320px; background: #f8f9fa; border: 1px solid #dee2e6; border-radius: 8px; padding: 20px;">
            <div style="font-size: 16px; font-weight: 600; margin-bottom: 12px; color: #212529;">
                Avg Selling Price
            </div>
            <div style="font-size: 28px; font-weight: 700; color: #212529;">
                <field name="avg_selling_price"
                       readonly="1"
                       nolabel="1"
                       widget="monetary"
                       options="{'currency_field': 'currency_id'}"/>
            </div>
        </div>
    </div>
</div>

<!-- ACTIONS -->
<div class="mt-4">
    <h2>Actions</h2>
    <div style="display: flex; gap: 16px; flex-wrap: wrap; margin-top: 16px; align-items: flex-start;">
        <button name="action_open_sold_properties"
                type="object"
                string="Open Sold Properties"
                class="btn btn-primary"
                icon="fa-money"
                style="padding: 12px 24px; min-width: 220px;"/>

        <button name="action_open_rejected_offers"
                type="object"
                string="Open Rejected Offers"
                class="btn btn-primary"
                icon="fa-ban"
                style="padding: 12px 24px; min-width: 220px;"/>
    </div>
</div>

                </sheet>
            </form>
        </field>
    </record>
</odoo>
