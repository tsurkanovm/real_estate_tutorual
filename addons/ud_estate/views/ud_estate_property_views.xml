<?xml version="1.0"?>
<odoo>
    <!--    Property views -->
    <record id="ud_estate_property_action" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">ud_estate.property</field>
        <field name="view_mode">list,form</field>
        <!--        <field name="context">{'search_default_available': True}</field> remove this default filter temporary -->
    </record>

    <record id="ud_estate_property_list" model="ir.ui.view">
        <field name="name">ud_estate.property.list</field>
        <field name="model">ud_estate.property</field>
        <field name="arch" type="xml">
            <list string="Properties" default_order="price asc"
                  decoration-muted="state == 'sold'"
                  decoration-danger="state == 'cancelled'"
                  decoration-success="state == 'received' or state == 'accepted'"
                  decoration-bf="state == 'accepted'">
                <field name="id"/>
                <field name="name"/>
                <field name="postcode"/>
                <field name="tag_ids" widget="many2many_tags" string="" options="{'color_field': 'color'}"/>
                <field name="bedrooms"/>
                <field name="living_area" string="Living Area (sqm)"/>
                <field name="price"/>
                <field name="best_offer"/>
                <field name="available_from" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="ud_estate_property_form" model="ir.ui.view">
        <field name="name">ud_estate.property.form</field>
        <field name="model">ud_estate.property</field>
        <field name="arch" type="xml">
            <form string="Property">
                <header>
                    <button name="action_set_sold" type="object" string="SOLD"
                            invisible="state == 'sold' or state == 'cancelled'"/>
                    <button name="action_set_cancelled" type="object" string="CANCEL"
                            invisible="state == 'sold' or state == 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="new, received, accepted, sold"/>
                </header>
                <sheet>
                    <group>
                        <h1>
                            <field name="name"/>
                        </h1>
                        <field name="tag_ids" widget="many2many_tags" string="" options="{'color_field': 'color'}"/>
                    </group>

                    <group>
                        <group>
                            <field name="type_id" options="{'no_create': True}"/>
                            <field name="postcode"/>
                            <field name="available_from"/>
                        </group>
                        <group>
                            <field name="expected_price"/>
                            <field name="price"/>
                            <field name="best_offer"/>
                        </group>

                        <notebook>
                            <page string="Description">
                                <group>
                                    <field name="description"/>
                                    <field name="bedrooms"/>
                                    <field name="living_area"/>
                                    <field name="facades"/>
                                    <field name="garage"/>
                                    <field name="garden"/>
                                    <field name="garden_area" invisible="not garden"/>
                                    <field name="garden_orientation" invisible="not garden"/>
                                    <field name="total_area"/>
                                </group>
                            </page>
                            <page string="Offers">
                                <field name="offer_ids" widget="one2many" mode="list" readonly="state !='new'"/>
                            </page>
                            <page string="Other information">
                                <group>
                                    <field name="user_id"/>
                                    <field name="partner_id"/>
                                </group>
                            </page>
                        </notebook>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="ud_estate_property_filter" model="ir.ui.view">
        <field name="name">ud_estate.property.filter</field>
        <field name="model">ud_estate.property</field>
        <field name="arch" type="xml">
            <search string="Properties">
                <field name="postcode"/>
                <field name="bedrooms"/>
                <field name="price" string="Expected Price"/>
                <field name="living_area" string="Living Area (sqm)"
                       filter_domain="[('living_area', '>=', self)]"/>
                <field name="facades"/>
                <filter string="Available" name="available"
                        domain="['|', ('state', '=', 'new'), ('state', '=', 'received')]"/>
                <group>
                    <filter name="postcode" context="{'group_by': 'postcode'}"/>
                </group>
            </search>
        </field>
    </record>

    <!--  Offer views  -->
    <record id="ud_estate_property_offer_action" model="ir.actions.act_window">
        <field name="name">Property Offers</field>
        <field name="res_model">ud_estate.property.offer</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('property_type_id', '=', active_id)]</field>
    </record>
    <record id="ud_estate_property_offer_tree" model="ir.ui.view">
        <field name="name">ud_estate.property.offer.tree</field>
        <field name="model">ud_estate.property.offer</field>
        <field name="arch" type="xml">
            <list string="Offers" editable="bottom" decoration-success="status=='accepted'"
                  decoration-danger="status=='rejected'">
                <field name="price"/>
                <field name="partner_id"/>
                <field name="validity" string="Validity (days)"/>
                <field name="date_deadline"/>
                <button name="action_set_accept" type="object" icon="fa-check" title="Accept Offer"
                        invisible="status == 'accepted' or status == 'rejected'"/>
                <button name="action_set_reject" type="object" icon="fa-close" title="Reject Offer"
                        invisible="status == 'accepted' or status == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="ud_estate_offer_form" model="ir.ui.view">
        <field name="name">ud_estate.offer.form</field>
        <field name="model">ud_estate.property.offer</field>
        <field name="arch" type="xml">
            <form string="Offer">
                <sheet>
                    <group>
                        <field name="price"/>
                        <field name="partner_id"/>
                        <field name="validity" string="Validity (days)"/>
                        <field name="date_deadline"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!--    Property type views -->
    <record id="ud_estate_property_type_action" model="ir.actions.act_window">
        <field name="name">Property Types</field>
        <field name="res_model">ud_estate.property.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="ud_estate_property_type_tree" model="ir.ui.view">
        <field name="name">ud_estate.property.type.tree</field>
        <field name="model">ud_estate.property.type</field>
        <field name="arch" type="xml">
            <list string="Property Types">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="ud_estate_property_type_form" model="ir.ui.view">
        <field name="name">ud_estate.property.type.form</field>
        <field name="model">ud_estate.property.type</field>
        <field name="arch" type="xml">
            <form string="Property">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button"
                                name="%(ud_estate_property_offer_action)d"
                                type="action"
                                icon="fa-file-text-o"
                                help="Offers for a type of property">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_value d-flex gap-1">
                                    <field name="offer_count" widget="statinfo" nolabel="1" class="oe_inline"/>
                                </span>
                                <span class="o_stat_text">Offers</span>
                            </div>
                        </button>
                    </div>
                    <h1 class="mb32">
                        <field name="name"/>
                    </h1>
                    <notebook>
                        <page string="Properties">
                            <field name="property_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="expected_price"/>
                                    <field name="state" string="Status"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!--    Property Tag  views -->
    <record id="ud_estate_property_tag_action" model="ir.actions.act_window">
        <field name="name">Property Tags</field>
        <field name="res_model">ud_estate.property.tag</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>