<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="base.module_category_real_estate_brokerage" model="ir.module.category">
        <field name="description">Helps you manage real estates.</field>
        <field name="sequence">5</field>
    </record>

<!--    Will use in Odoo 19, commented for now  -->
<!--    <record model="res.groups.privilege" id="groups_privilege_real_estate">-->
<!--        <field name="name">Real Estate</field>-->
<!--        <field name="sequence">10</field>-->
<!--        <field name="category_id" ref="base.module_category_real_estate_brokerage"/>-->
<!--    </record>-->

    <record id="estate_group_user" model="res.groups">
      <field name="name">Agent</field>
      <field name="category_id" ref="base.module_category_real_estate_brokerage"/>
    </record>

  <record id="estate_group_manager" model="res.groups">
      <field name="name">Manager</field>
      <field name="category_id" ref="base.module_category_real_estate_brokerage"/>
      <field name="implied_ids" eval="[(4, ref('ud_estate.estate_group_user'))]"/>
    </record>

    <record id="estate_agent_property_rule" model="ir.rule">
        <field name="name">Real Estate: agents: see only own or not set salesmen property</field>
        <field name="model_id" ref="model_ud_estate_property"/>
        <field name="perm_read" eval="True"/>
        <field name="groups" eval="[(4,ref('ud_estate.estate_group_user'))]"/>
        <field name="domain_force">[
            '|', ('user_id', '=', user.id),
            ('user_id', '=', False)
            ]
        </field>
    </record>
    <record id="estate_manager_property_rule" model="ir.rule">
        <field name="name">Real Estate: manager sees all properties</field>
        <field name="model_id" ref="model_ud_estate_property"/>
        <field name="perm_read" eval="True"/>
        <field name="groups" eval="[(4, ref('ud_estate.estate_group_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>